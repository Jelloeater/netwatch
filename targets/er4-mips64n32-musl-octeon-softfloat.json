{
  "llvm-target": "mips64-unknown-linux-musl",
  "data-layout": "e-m:e-i64:64-n32:64-S128",
  "arch": "mips64",
  "os": "linux",
  "env": "musl",

  "target-endian": "big",
  "target-pointer-width": "64",

  "linker-flavor": "ld.lld",

  "cpu": "octeon",
  "features": "+soft-float",

  "executables": true,
  "dynamic-linking": false,
  "position-independent-executables": false,
  "relocation-model": "static",

  "pre-link-args": {
    "ld.lld": [
      "-melf32btsmipn32",
      "-static"
    ]
  }
}
